# App
NODE_ENV=development
PORT=3000

# PostgreSQL (must match docker-compose or your DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fintrack
POSTGRES_PASSWORD=fintrack_secret
POSTGRES_DB=fintrack

# Connection URL (optional; if set, overrides individual vars above)
# Локально: postgresql://fintrack:fintrack_secret@localhost:5432/fintrack
# Продакшен (Supabase): Connect → URI, Method = Session pooler или Transaction pooler (порт 6543, не Direct — для IPv4/Vercel)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@...pooler.supabase.com:6543/postgres

# Auth — JWT (change in production)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Auth — cookie (for refresh token)
REFRESH_COOKIE_NAME=fintrack_refresh
# lax — локально; none — на Vercel, когда фронт и бэк на разных доменах (fintrack-front-*.vercel.app vs fintrack-back-*.vercel.app)
COOKIE_SAME_SITE=lax

# Auth — Google OAuth (for /auth/google)
GOOGLE_CLIENT_ID=826258042010-89g41bvu4pgr7quo9ngvltid31rk42j7.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/auth/google/callback

# Frontend URL (for CORS and Google redirect after login)
FRONTEND_URL=http://localhost:3001

OPENAI_API_KEY=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
