{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "dist/vercel-entry.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/vercel-entry.js"
    }
  ]
}
